# User-specific configuration (paths, local tools).
# Template is config.example.psd1.
config.psd1

# Build output (regenerable via Build-WindroseMod.ps1 / Build-AllStackVariations.ps1).
Builds/

# Build artefacts from Init/Apply (regenerable via Build-AllStackVariations.ps1).
# Sources/Vanilla/ is intentionally tracked -- snapshot of the game, only
# regenerable via the UE4SS Lua mod.
Sources/StackSize_*/

# Historical dead-ends and debug artefacts. Not repo-relevant.
Archive/

# Build metadata (written by Build-WindroseMod.ps1 -Action Init).
_INIT.txt

# UE4SS mod output (populated by VanillaItemDumper at runtime).
ue4ss-mods/VanillaItemDumper/Dumps/

# Windows cruft.
Thumbs.db
desktop.ini

# Editor artefacts.
.vscode/
.idea/
*.swp
*~
