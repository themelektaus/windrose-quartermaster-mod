<Project>
  <!--
    Single-file self-contained publish profile.
    Usage: dotnet publish GUI/App /p:PublishProfile=win-x64
    Output: GUI/App/bin/Publish/Quartermaster.exe (one file, ~80 MB)
  -->
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>bin\Publish\</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <DebugType>embedded</DebugType>
  </PropertyGroup>

  <!--
    Post-publish cleanup: WebView2 ships ~750 KB of XML docs that get copied
    even with CopyDocumentationFilesFromPackages=false (NuGet quirk), and
    the Web project leaves a deps.json/runtimeconfig.json behind that App
    doesn't read since everything is bundled into the single .exe.
  -->
  <Target Name="QuartermasterStripPublishLeftovers" AfterTargets="Publish">
    <ItemGroup>
      <_QmLeftovers Include="$(PublishDir)Microsoft.Web.WebView2.*.xml" />
      <_QmLeftovers Include="$(PublishDir)Quartermaster.Web.deps.json" />
      <_QmLeftovers Include="$(PublishDir)Quartermaster.Web.runtimeconfig.json" />
    </ItemGroup>
    <Delete Files="@(_QmLeftovers)" />
  </Target>
</Project>
