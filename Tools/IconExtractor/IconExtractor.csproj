<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Windrose.IconExtractor</RootNamespace>
    <AssemblyName>Windrose.IconExtractor</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <InvariantGlobalization>true</InvariantGlobalization>
    <DebugType>embedded</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\CUE4Parse\CUE4Parse\CUE4Parse.csproj" />
    <ProjectReference Include="..\CUE4Parse\CUE4Parse-Conversion\CUE4Parse-Conversion.csproj" />
    <PackageReference Include="SkiaSharp"            Version="2.88.9" />
    <PackageReference Include="SkiaSharp.NativeAssets.Win32" Version="2.88.9"
        Condition="'$(RuntimeIdentifier)' == 'win-x64' OR ('$(RuntimeIdentifier)' == '' AND !$([MSBuild]::IsOSPlatform('Linux')))" />
    <PackageReference Include="SkiaSharp.NativeAssets.Linux"   Version="2.88.9"
        Condition="'$(RuntimeIdentifier)' == 'linux-x64' OR ('$(RuntimeIdentifier)' == '' AND $([MSBuild]::IsOSPlatform('Linux')))" />
  </ItemGroup>

  <PropertyGroup>
    <_CUE4ParseCsproj>$(MSBuildThisFileDirectory)..\CUE4Parse\CUE4Parse\CUE4Parse.csproj</_CUE4ParseCsproj>
    <_ModRoot>$(MSBuildThisFileDirectory)..\..</_ModRoot>
  </PropertyGroup>
  <Target Name="EnsureCUE4ParseSubmodule"
          BeforeTargets="CollectPackageReferences;ResolveProjectReferences;CollectResolvedSDKReferencesDesignTime"
          Condition="!Exists('$(_CUE4ParseCsproj)')">
    <Message Importance="high" Text="[Quartermaster] CUE4Parse submodule not initialized - running git submodule update --init" />
    <Exec Command="git submodule update --init --progress Tools/CUE4Parse"
          WorkingDirectory="$(_ModRoot)"
          ContinueOnError="true">
      <Output TaskParameter="ExitCode" PropertyName="_GitSubmoduleExit" />
    </Exec>
    <Error Condition="'$(_GitSubmoduleExit)' != '0' OR !Exists('$(_CUE4ParseCsproj)')"
           Text="Could not initialize the CUE4Parse submodule. Either re-clone the repository with the recursive flag, install Git for Windows (https://git-scm.com/download/win) so the auto-init step can run, or grab CUE4Parse manually from https://github.com/FabianFG/CUE4Parse into Tools/CUE4Parse/." />
  </Target>

</Project>
